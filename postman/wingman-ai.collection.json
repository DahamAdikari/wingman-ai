          }
        },

        {
          "name": "List Assets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/assets",
              "host": ["{{base_url}}"],
              "path": ["api", "assets"]
            },
            "description": "List all assets for the authenticated manager across all projects."
          }
        },

        {
          "name": "List Assets by Project",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/assets?project_id={{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "assets"],
              "query": [{ "key": "project_id", "value": "{{project_id}}" }]
            },
            "description": "List assets filtered to a specific project."
          }
        },

        {
          "name": "Delete Asset",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/assets/{{asset_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "assets", "{{asset_id}}"]
            },
            "description": "Delete an asset. Scoped to the authenticated manager — cannot delete another manager's assets."
          }
        }

      ]
    },

    {
      "name": "Notifications",
      "description": "In-app notifications for managers and clients. (Requires notification-service — not yet built.)",
      "item": [

        {
          "name": "List My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/notifications",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"]
            },
            "description": "Fetch all notifications for the authenticated user. Filter with `?unread=true` for unread only."
          }
        },

        {
          "name": "List Unread Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/notifications?unread=true",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [{ "key": "unread", "value": "true" }]
            },
            "description": "Fetch only unread notifications."
          }
        },

        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/notifications/{{notif_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "{{notif_id}}", "read"]
            },
            "description": "Mark a single notification as read."
          }
        }

      ]
    },

    {
      "name": "Scheduler",
      "description": "Schedule approved posts for publishing. (Requires scheduler-service — not yet built.)",
      "item": [

        {
          "name": "Schedule a Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"post_id\": \"{{post_id}}\",\n  \"scheduled_at\": \"2026-05-01T09:00:00Z\",\n  \"platform\": \"instagram\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/schedule",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule"]
            },
            "description": "Schedule an approved post for publishing. The post must have status `approved`. Emits `READY_TO_PUBLISH` at the scheduled time."
          }
        },

        {
          "name": "Cancel Schedule",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/schedule/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "schedule", "{{post_id}}"]
            },
            "description": "Cancel a pending scheduled post. Only works if status is still `pending` (not yet fired)."
          }
        }

      ]
    },

