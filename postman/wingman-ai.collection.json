            },
            "description": "Fetch a single user by ID. Returns 404 if the user does not belong to the authenticated manager."
          }
        }

      ]
    },

    {
      "name": "Content",
      "description": "Post creation and AI content generation.",
      "item": [

        {
          "name": "Create Post (Trigger AI Generation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const postId = res.post?.id || res.id;",
                  "if (postId) {",
                  "    pm.collectionVariables.set('post_id', postId);",
                  "    console.log('post_id saved:', postId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"platform\": \"instagram\",\n  \"image_prompt\": \"A vibrant Nike running shoe on a city street at sunrise, energetic mood, photorealistic\",\n  \"prompt\": \"Launch campaign for Air Max 2026 — motivational tone, include #JustDoIt\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/content",
              "host": ["{{base_url}}"],
              "path": ["api", "content"]
            },
            "description": "Create a new post and trigger AI image + caption generation. Platform must be one of: `instagram` | `linkedin` | `twitter`. `post_id` is auto-saved."
          }
        },

        {
          "name": "Create Post for LinkedIn",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{project_id}}\",\n  \"platform\": \"linkedin\",\n  \"image_prompt\": \"Professional Nike brand imagery, corporate setting, clean white background\",\n  \"prompt\": \"B2B partnership announcement — formal tone, 200 words max\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/content",
              "host": ["{{base_url}}"],
              "path": ["api", "content"]
            },
            "description": "Create a LinkedIn post."
          }
        },

        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/content/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "content", "{{post_id}}"]
            },
            "description": "Fetch a single post with its latest version (caption, image URL, version number)."
          }
        }

      ]
    },

    {
      "name": "Reviews",
      "description": "Approval loop — manager and client review decisions.\n\nFlow: manager_review → (manager approves) → client_review → (client approves) → approved\nRejection at any stage sends back to content-service for AI regeneration.",
      "item": [

        {
          "name": "Manager — Approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_id\": \"{{manager_id}}\",\n  \"reviewer_role\": \"manager\",\n  \"decision\": \"approved\",\n  \"feedback_text\": \"Looks great, sending to client.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/review/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "review", "{{post_id}}"]
            },
            "description": "Manager approves content. Emits `MANAGER_APPROVED` — post moves to `client_review` stage."
          }
        },

        {
          "name": "Manager — Reject",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_id\": \"{{manager_id}}\",\n  \"reviewer_role\": \"manager\",\n  \"decision\": \"rejected\",\n  \"feedback_text\": \"The image doesn't match the brand guidelines. Please use darker tones and remove the text overlay.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/review/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "review", "{{post_id}}"]
            },
            "description": "Manager hard-rejects content. Emits `CONTENT_REJECTED` — content-service regenerates with the feedback attached."
          }
        },

        {
          "name": "Manager — Request Changes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_id\": \"{{manager_id}}\",\n  \"reviewer_role\": \"manager\",\n  \"decision\": \"changes_requested\",\n  \"feedback_text\": \"Caption is too long. Shorten to under 100 words and make the tone more casual.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/review/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "review", "{{post_id}}"]
            },
            "description": "Manager requests changes. Emits `CONTENT_REJECTED` with feedback — content-service regenerates."
          }
        },

        {
          "name": "Client — Approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_id\": \"{{user_id}}\",\n  \"reviewer_role\": \"client\",\n  \"decision\": \"approved\",\n  \"feedback_text\": \"Perfect! This represents our brand well.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/review/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "review", "{{post_id}}"]
            },
            "description": "Client approves content. Emits `CONTENT_APPROVED` — post moves to `approved` and becomes ready for scheduling."
          }
        },

        {
          "name": "Client — Request Changes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_id\": \"{{user_id}}\",\n  \"reviewer_role\": \"client\",\n  \"decision\": \"changes_requested\",\n  \"feedback_text\": \"Please make the tone more formal and add our product tagline: 'Built to Last'.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/review/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "review", "{{post_id}}"]
            },
            "description": "Client requests changes. Emits `CLIENT_FEEDBACK` — content-service regenerates with the new feedback."
          }
        },

        {
          "name": "Get Review State",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/review/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "review", "{{post_id}}"]
            },
            "description": "Get the current approval state for a post — current stage, manager_approved, client_approved flags, and full review history."
          }
        }

      ]
    },

    {
