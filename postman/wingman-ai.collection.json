{
  "info": {
    "name": "Wingman AI API",
    "_postman_id": "wingman-ai-v1",
    "description": "Complete API collection for the Wingman AI marketing SaaS platform.\n\nAll protected routes require a Bearer token — run **Register Manager** or **Login** first and the token is saved automatically to the `token` collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    { "key": "base_url",      "value": "http://localhost:4000",  "type": "string" },
    { "key": "token",         "value": "",                        "type": "string" },
    { "key": "manager_id",    "value": "",                        "type": "string" },
    { "key": "project_id",    "value": "",                        "type": "string" },
    { "key": "user_id",       "value": "",                        "type": "string" },
    { "key": "post_id",       "value": "",                        "type": "string" },
    { "key": "asset_id",      "value": "",                        "type": "string" },
    { "key": "notif_id",      "value": "",                        "type": "string" }
  ],

  "item": [

    {
      "name": "Auth",
      "description": "Public routes — no token needed. Login / Register auto-save the token.",
      "item": [

        {
          "name": "Register Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    pm.collectionVariables.set('manager_id', res.manager.id);",
                  "    console.log('Token saved:', res.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Manager\",\n  \"email\": \"manager@wingman.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new manager account. Returns a JWT token and manager object. Token is auto-saved to the `token` collection variable."
          }
        },

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    pm.collectionVariables.set('manager_id', res.manager.id);",
                  "    console.log('Token saved:', res.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@wingman.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate a manager and receive a JWT token. Token is auto-saved to the `token` collection variable."
          }
        }

      ]
    },

    {
      "name": "Projects",
      "description": "Project management — create, list, update projects and manage members.",
      "item": [

        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "    pm.collectionVariables.set('project_id', res.id);",
                  "    console.log('project_id saved:', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nike\",\n  \"description\": \"Nike social media campaign — Q3 2026\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/projects",
              "host": ["{{base_url}}"],
              "path": ["api", "projects"]
            },
            "description": "Create a new client project. `project_id` is auto-saved."
          }
        },

        {
          "name": "List Projects (Dashboard)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/projects",
              "host": ["{{base_url}}"],
              "path": ["api", "projects"]
            },
            "description": "Returns the denormalised dashboard view from query-service. Fast single-query read — no joins."
          }
        },

        {
          "name": "Get Project Detail (Fan-out)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/detail",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}", "detail"]
            },
            "description": "API Composition — gateway fans out in parallel to content-service, review-service, and user-service, then assembles a single response with `content`, `reviews`, and `members`."
          }
        },

        {
          "name": "Get Project Posts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/posts",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}", "posts"]
            },
            "description": "List all posts for a project from content-service."
          }
        },

        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nike (Updated)\",\n  \"description\": \"Updated campaign description\",\n  \"status\": \"active\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}"]
            },
            "description": "Update project name, description, or status (`active` | `archived`). All fields are optional — only provided fields are changed."
          }
        },

        {
          "name": "Archive Project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"archived\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}"]
            },
            "description": "Archive a project by setting status to `archived`."
          }
        },

        {
          "name": "Add Member to Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"role\": \"client\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/projects/{{project_id}}/members",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}", "members"]
            },
            "description": "Enrol a user into a project with a role. Role must be one of: `client` | `reviewer` | `viewer`."
          }
        }

      ]
    },

