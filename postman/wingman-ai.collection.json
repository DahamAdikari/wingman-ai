            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Designer\",\n  \"email\": \"alex@agency.com\",\n  \"role\": \"team_member\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/users",
